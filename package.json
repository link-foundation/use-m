{
  "name": "use-m",
  "version": "8.14.1",
  "description": "use-m: dynamically import any JavaScript module",
  "type": "module",
  "main": "src/use.cjs",
  "exports": {
    ".": {
      "import": "./src/use.mjs",
      "require": "./src/use.cjs"
    },
    "./use.cjs": "./src/use.cjs",
    "./use.mjs": "./src/use.mjs",
    "./load": {
      "import": "./src/load.mjs",
      "require": "./src/load.cjs"
    },
    "./load.cjs": "./src/load.cjs",
    "./load.mjs": "./src/load.mjs"
  },
  "bin": {
    "use": "src/cli.mjs"
  },
  "scripts": {
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "test:examples": "./examples/test-examples.mjs",
    "sync:entries": "node scripts/sync-root-entries.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/link-foundation/use-m.git"
  },
  "bugs": {
    "url": "https://github.com/link-foundation/use-m/issues"
  },
  "keywords": [
    "use",
    "import",
    "require",
    "npm",
    "backend",
    "frontend",
    "auto load",
    "auto install",
    "cache",
    "global require",
    "global import",
    "dynamic require",
    "dynamic import",
    "package loader",
    "module loader",
    "dependency management",
    "zx",
    "execa",
    "esm.sh",
    "esm",
    "unpkg.com",
    "unpkg"
  ],
  "author": "link-foundation",
  "license": "Unlicense",
  "files": [
    "use.mjs",
    "use.cjs",
    "use.js",
    "src/use.mjs",
    "src/use.cjs",
    "src/use.js",
    "src/cli.mjs",
    "src/loader.js",
    "src/load.mjs",
    "src/load.cjs",
    "src/test-adapter.mjs",
    "src/test-adapter.cjs",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "babel-jest": "^29.7.0",
    "command-stream": "^0.0.5",
    "express": "^5.1.0",
    "jest": "^29.7.0",
    "puppeteer": "^24.16.2"
  }
}
